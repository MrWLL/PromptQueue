{
  "name": "promptqueue",
  "displayName": "PromptQueue",
  "publisher": "local",
  "description": "在 VS Code 侧边栏中按顺序管理和复制提示词。",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.111.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onView:promptQueue.sidebar",
    "onCommand:promptQueue.copyItem"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "promptQueue.copyItem",
        "title": "复制提示词"
      },
      {
        "command": "promptQueue.toggleUsed",
        "title": "切换已使用状态"
      },
      {
        "command": "promptQueue.moveItemUp",
        "title": "上移提示词"
      },
      {
        "command": "promptQueue.moveItemDown",
        "title": "下移提示词"
      },
      {
        "command": "promptQueue.deleteItem",
        "title": "删除提示词"
      },
      {
        "command": "promptQueue.resetAllUsed",
        "title": "全部标记为未使用"
      },
      {
        "command": "promptQueue.bulkImport",
        "title": "批量导入提示词"
      },
      {
        "command": "promptQueue.addItem",
        "title": "新增提示词"
      },
      {
        "command": "promptQueue.editItem",
        "title": "编辑提示词"
      }
    ],
    "menus": {
      "view/item/context": [
        {
          "command": "promptQueue.copyItem",
          "group": "inline@1",
          "when": "view == promptQueue.sidebar && viewItem == promptQueue.item"
        },
        {
          "command": "promptQueue.toggleUsed",
          "group": "inline@2",
          "when": "view == promptQueue.sidebar && viewItem == promptQueue.item"
        },
        {
          "command": "promptQueue.moveItemUp",
          "group": "navigation@1",
          "when": "view == promptQueue.sidebar && viewItem == promptQueue.item"
        },
        {
          "command": "promptQueue.moveItemDown",
          "group": "navigation@2",
          "when": "view == promptQueue.sidebar && viewItem == promptQueue.item"
        },
        {
          "command": "promptQueue.deleteItem",
          "group": "inline@3",
          "when": "view == promptQueue.sidebar && viewItem == promptQueue.item"
        },
        {
          "command": "promptQueue.editItem",
          "group": "inline@4",
          "when": "view == promptQueue.sidebar && viewItem == promptQueue.item"
        }
      ],
      "view/title": [
        {
          "command": "promptQueue.addItem",
          "group": "navigation@1",
          "when": "view == promptQueue.sidebar"
        },
        {
          "command": "promptQueue.bulkImport",
          "group": "navigation@2",
          "when": "view == promptQueue.sidebar"
        },
        {
          "command": "promptQueue.resetAllUsed",
          "group": "navigation@3",
          "when": "view == promptQueue.sidebar"
        }
      ]
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "promptQueue",
          "title": "提示词队列",
          "icon": "media/promptqueue.svg"
        }
      ]
    },
    "views": {
      "promptQueue": [
        {
          "id": "promptQueue.sidebar",
          "name": "提示词队列"
        }
      ]
    }
  },
  "scripts": {
    "compile": "tsc -p .",
    "test:unit": "vitest run --passWithNoTests --config vitest.config.ts",
    "test:integration": "npm run compile && node ./out/test/runTest.js",
    "test": "npm run test:unit && npm run test:integration"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.6.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
