{
  "name": "promptqueue",
  "displayName": "PromptQueue",
  "publisher": "local",
  "description": "Manage reusable prompt queues for agent workflows in the VS Code sidebar.",
  "version": "0.0.1",
  "license": "MIT",
  "icon": "media/promptqueue-marketplace.png",
  "engines": {
    "vscode": "^1.111.0"
  },
  "extensionKind": [
    "workspace"
  ],
  "capabilities": {
    "virtualWorkspaces": {
      "supported": false
    }
  },
  "categories": [
    "Productivity"
  ],
  "keywords": [
    "prompt",
    "agent",
    "queue",
    "clipboard",
    "sidebar",
    "workflow"
  ],
  "activationEvents": [
    "onView:promptQueue.sidebar"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "configuration": {
      "title": "PromptQueue",
      "properties": {
        "promptQueue.storagePath": {
          "type": "string",
          "scope": "resource",
          "default": "WorkSpace/PromptQueue",
          "description": "PromptQueue 数据的存储目录。支持工作区相对路径或绝对路径。"
        },
        "promptQueue.uiLanguage": {
          "type": "string",
          "scope": "resource",
          "default": "zh-CN",
          "enum": [
            "zh-CN",
            "en"
          ],
          "enumDescriptions": [
            "简体中文",
            "English"
          ],
          "description": "PromptQueue Webview 界面的显示语言。"
        }
      }
    },
    "viewsContainers": {
      "activitybar": [
        {
          "id": "promptQueue",
          "title": "队列",
          "icon": "media/promptqueue.svg"
        }
      ]
    },
    "views": {
      "promptQueue": [
        {
          "id": "promptQueue.sidebar",
          "name": "队列",
          "type": "webview"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p .",
    "test:unit": "vitest run --passWithNoTests --config vitest.config.ts",
    "test:integration": "npm run compile && node ./out/test/runTest.js",
    "test": "npm run test:unit && npm run test:integration"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "^24.6.0",
    "@types/vscode": "^1.110.0",
    "@vscode/test-electron": "^2.5.2",
    "mocha": "^11.7.4",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
